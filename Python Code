import pygame # used to draw the maze and take inputs
import time # used to track time for lose condition


subprocess.run(['matlab', '-r', 'MazeGame'], check=True)
while not (os.path.exists("maze1.txt") and os.path.exists("maze2.txt") and os.path.exists("maze3.txt")):
    time.sleep(0.1)

pygame.init() # initializes all pygame modules

WIDTH = 1000 
HEIGHT = 1000 # 1000 x 1000 pixels
TILE_SIZE = 50 # tile size is 50 so it will be a 20 x 20 tile map

screen = pygame.display.set_mode((WIDTH, HEIGHT)) # creates the game window with the pre set dimensions
pygame.display.set_caption("Maze Game") # adds a title that is on the top right part of the game window

clock = pygame.time.Clock() # this creates a clock object to control the fps of the game. it moves too fast without this

current_level = 1 # starts on the first level
maze, position = load_level(current_level) # loads the maze and starting position

key_state = False # makes sure the player doesn't start witht the key and tracks it for later
start_time = time.time() # time when player clicks run. exact time doesn't matter because it compares with current_time to find elapsed time
time_limit = 120 # set the limit to 120 seconds. seems like a good medium of not too long or short

running = True # flag

while running:
    clock.tick(60) # lock framerate at 60fps to slow the game down

    for event in pygame.event.get(): # loops through all player inputs such as keyboard inputs or closing the window.
        if event.type == pygame.QUIT: # shuts the game down when user clicks the close window button
            running = False

        if event.type == pygame.KEYDOWN: # this will handle movement
            keys = pygame.key.get_pressed() # takes the current state of all keys
            if current_level == 2:
                direction = direction_scramble(keys) # only scrambles inputs when you are in level 2
            else:
                direction = get_direction(keys)

            position = move(position, direction, maze) # move the player based on directions and maze collision

            if event.key == pygame.K_SPACE and current_level == 3: # used for wall swap and ensures it only activates on level 3
                maze = wall_swap(maze, position)
        
    key_state, maze = key_pickup(maze, position, key_state, current_level) # checks for if player has picked up the key (should only activate when player is on map 3 and correct coordinate)

    
    new_level = switch_level(current_level, position, maze) # handles switching level depending on current level and if player is on the doorway tile

    if new_level != current_level: # if the level changes, load the correct maze and set plaer to correct start position
        current_level = new_level # updates the current level to the new level number
        maze, position = load_level(current_level) # loads the new level

    if win(position, current_level, key_state, maze): # handles win if player has key, on level 1, and is on the correct tile
        print("\nYou Win!\n") # prints the user won in the terminal with an empty line above and below for readability
        running = False # this closes pygame due to the close item outside of the while loop at the end of the code

    if time_check(start_time, time_limit): # this handles if the player lost by taking too much time
        print("\nTime's up! You lose.\n") # same concept as the win text
        running = False # same as the win function
    
    screen.fill((0, 0, 0)) # clears map to ensure the color from the player and key changes update the map. without this, the user color 'smears' across the maze

    for y in range(len(maze)):
        for x in range(len(maze[0])): # loops through every tile in the maze and draws it with the correct color
            tile = maze[y][x]
            rect = pygame.Rect(x * TILE_SIZE, y * TILE_SIZE, TILE_SIZE, TILE_SIZE) # creates a rectangle for the tile's position on the screen

            if tile == 1:
                #                          ⌄ the color values (1st = red, 2nd = grenn, 3rd = blue)
                pygame.draw.rect(screen, (255, 255, 255), rect) # draws white rectangles for walls
                # ^draws rectangle ^the screen is what we are drawing on
            elif tile == 5:
                pygame.draw.rect(screen, (100, 100, 100), rect) # draws grey rectangles for boarder
            elif tile == 4:
                pygame.draw.rect(screen, (0, 0, 255), rect) # draws doors in blue
            elif tile == 6:
                pygame.draw.rect(screen, (0, 0, 255), rect) # 6 is the backwards door on map 2 and it will also be blue
            elif tile == 2:
                pygame.draw.rect(screen, (255, 255, 0), rect) # makes keys yellow because that color is associated with most keys in games
            elif tile == 9:
                pygame.draw.rect(screen, (0, 255, 0), rect) # makes the goal tile green because green indicates a win

    player_x, player_y = position # draws the player as a red rectangle the same size as other tiles on top of the maze
    pygame.draw.rect(screen, (255, 0, 0),
                     (player_x * TILE_SIZE, player_y * TILE_SIZE, TILE_SIZE, TILE_SIZE))

    pygame.display.flip() # updates the display so everything appears on screen

pygame.quit() # outside the while loop so when we break out, it closes pygame which closes the window and maze
