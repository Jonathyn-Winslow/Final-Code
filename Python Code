

def load_map(filename):
    """This takes the maze text file and turns it into a list for the GUI"""
    maze = [] #starts with an empty list
    with open(filename, 'r') as file:
        for line in file:
            string_values = line.strip().split() # removes garbage at ends of the string and splits each term into its own element
                
            ints = []
            for n in string_values:
                numbers = int(n) # changes the strings into integers
                ints.append(numbers) 

            maze.append(ints) # adds each integer into the maze list
    
    return maze

def start_pos(maze):
    """finds the starting position of the player"""
    for y in range(len(maze)): # goes through the rows of the maze
        for x in range(len(maze[0])): # goes through the columns. we need to do this because this is a 2D array
            if maze[y][x] == 3: # 3 is the player
                player = (x, y) # creates a tuple with the players location
                maze[y][x] = 0 # sets the player value to empty space to ensure the collision check doesn't get confused
                return player # returns the tuple    
            
def move(position, direction, maze):
    """filler"""
    x, y = position
    dx, dy = direction # used dy and dx because it helps me visualize movement because T'm used to math

    new_x = x + dx # adds position and movement to get the new position
    new_y = y + dy

    if maze[new_y][new_x] != 1 and maze[new_y][new_x] != 5: # 1 is a wall and 5 is the boarder so this ensures that we can't move through it
        return (new_x, new_y)
    
    return position

def get_direction(keys):
    """Utilizes pygame to take arrow key inputs and turns them into a direction tuple"""
    if keys[pygame.K_UP]: #pygame for up arrow
        return (0, -1) # the y axis is inverted in pygame due to our list setup so up is -1
    elif keys[pygame.K_DOWN]:
        return (0, 1) # left and right are still the normal direction
    elif keys[pygame.K_LEFT]:
        return (-1, 0)
    elif keys[pygame.K_RIGHT]:
        return (1, 0)
    else:
        return (0, 0) # if no input is registered, do nothing
    
def direction_scramble(keys):
    """Uses pygame to create direction tuples based on arrow key inputs but scrambles the directions"""
    if keys[pygame.K_UP]:
        return (1, 0) # for up arrow, it will go right
    elif keys[pygame.K_DOWN]:
        return (-1, 0)
    elif keys[pygame.K_LEFT]:
        return (0, 1)
    elif keys[pygame.K_RIGHT]:
        return (0, -1)
    else:
        return (0, 0)
    
def wall_swap(maze, position):
    """will swap all walls and empty spaces without effecting anything else"""
    for y in range(len(maze)): #goes doen the y axis of the list
        for x in range(len(maze[0])): # goes across the x axis of the list
            if (x, y) == position: # if the coordinate is on the player, this does nothing and doesn't swap the wall
                continue
            elif maze[y][x] == 1: 
                maze[y][x] = 0 # turns wall into empty space
            elif maze[y][x] == 0:
                maze[y][x] = 1 # turns empty space into a wall
            
    return maze # This doesn't effect items such as keys or doorways because they have different numbers assigned to them

def load_level(current_level):
    """will load the maze and starting position for the level"""
    if current_level == 1:
        filename = 'maze1.txt' # load the first map file
    elif current_level == 2:
        filename = 'maze2.txt' # load the second map file
    elif current_level == 3:
        filename = 'maze3.txt' # load the third map file

    maze = load_map(filename) # uses the previous load_map function to turn the text file into list
    position = start_pos(maze) # finds the start position of the new map file

    return maze, position

def switch_level(level, position, maze): # ChatGPT was used to debug this. I initially used position to change levels but it caused errors when you weren't in the perfect position
                                        # GPT gave me the idea to use the tiles we created instead and that fixed the issue
    """switches the level based on the player's position"""
    x, y = position

    if maze[y][x] == 4: # 4 is doorway to next level
        if level == 1:
            return 2 # only one doorway in this level
        elif level == 2:
            return 3 # this is the doorway at the end of map 2
        elif level == 3:
            return 2 # only doorway in map 3
    elif maze[y][x] == 6: # declared 6 to be secondary door in map 2 to return to map 1
        return 1

    return level

def win(position, current_level, key_state, maze):
    """checks if the player has won the game by being in the correct position with the key"""
    x, y = position
    if maze[y][x] and current_level == 1 and key_state == True: # must be on the correct tile, kave the key, and be on map 1
        return True
    
    return False

def time_check(start_time, time_limit):
    """checks if the time limit has been exceeded"""
    current_time = time.time() # takes the current time which doesn't matter if it is different between playthroughs
    elapsed = current_time - start_time # start time starts the moment you press run and this compares the 2 values to find how much time has passed

    if elapsed > time_limit: # time limit will be set just before the game loop starts to comare. we can change this at will
        return True
    
    return False

def key_pickup(maze, position, key_state, current_level): # used to place key, and check if it is picked up
    """checks if the player is on the key and removes key if so"""
    x, y = position

    if current_level == 3 and not key_state: # the only key is in level 3 so this checks if they are on level 3 and doesn't already have the key
    
        if maze[y][x] == 2: # if players position indexed into the maze is a 2, it marks the key_state to be true
            key_state = True
            maze[y][x] = 0 # turns key tile into empty space to show its no longer there
                    
    return key_state, maze

